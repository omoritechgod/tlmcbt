# Copy this to .env.local (locally) or paste into Vercel env vars (production)

# ---------- Required ----------
ADMIN_PASSWORD=tlm-admin-2026
JWT_SECRET=change-this-to-a-long-random-string-at-least-32-chars

# ---------- Turso (required for Vercel; optional locally) ----------
# Get these from: turso db show <db-name> --url
#                 turso db tokens create <db-name>
# If left empty, falls back to local SQLite file at ./data/cbt.db
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# ---------- Email (Resend) ----------
# Leave empty in dev — emails will just log to console
RESEND_API_KEY=
EMAIL_FROM=TLM Results <onboarding@resend.dev>
